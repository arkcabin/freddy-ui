NEXT_PUBLIC_COMING_SOON=true
# ─── DATABASE ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?sslmode=require"

# ─── BETTER AUTH ───────────────────────────────────────────────────────────
# You can generate a secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── SOCIAL PROVIDERS ──────────────────────────────────────────────────────
# Create these at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Create these at: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── POLAR CREDENTIALS ─────────────────────────────────────────────────────
# Polar Credentials (from Polar Dashboard)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID=
